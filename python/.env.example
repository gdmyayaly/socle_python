# Pour MYSQL
SGBD_SERVER_READ=localhost
SGBD_SERVER_WRITE=localhost
SGBD_PORT=3306
MYSQL_DATABASE=trppu
SGBD_APP_USER_READ=root
SGBD_APP_USER_WRITE=root
SGBD_APP_USER=root
SKIP_MYSQL=true
#SGBD_APP_PWD=your_password
SGBD_MAX_RETRIES=3
SGBD_RETRY_DELAY=1.0

# Databricks SQL Warehouse
DATABRICKS_SERVER_HOSTNAME=dbc-xxxxxxxx-xxxx.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxx
DATABRICKS_CLIENT_ID=your_client_id
DATABRICKS_CLIENT_SECRET=your_client_secret
DATABRICKS_CATALOG=gold
DATABRICKS_SCHEMA=default
DATABRICKS_TIMEOUT=120
DATABRICKS_MAX_RETRIES=3
DATABRICKS_RETRY_DELAY=2.0

# Pour voir les requetes envoyees a databricks
DEBUG_SHOW_QUERY=false

# json_formatter configuration
APP=dsr
APP_ENV=sdev  # Pour les env nous avons local,sdev,sacc,sass,prod
MODULE=ys04
APP_VERSION=1.0.0
# LOGS_DIR=/logs  (optionnel, utilise uniquement si APP_ENV=local ou chemin explicite)
